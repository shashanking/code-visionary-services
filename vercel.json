{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.codevisionaryservices.com" }],
      "destination": "https://codevisionaryservices.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/portfolio/:slug*",
      "destination": "/index.html"
    },
    {
      "source": "/blogs/:slug*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api|_vercel|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
