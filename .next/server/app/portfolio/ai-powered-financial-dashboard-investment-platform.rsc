lock","children":[{"_key":"74bdeefdcbea","_type":"span","marks":[],"text":"At Code Visionary Services, we don’t just build products—we create scalable digital experiences that drive real business outcomes."}],"markDefs":[],"style":"normal"},{"_key":"ad2366d37881","_type":"block","children":[{"_key":"86df1fb64fd4","_type":"span","marks":["strong"],"text":"Ready to bring your vision to life?"},{"_key":"b93eb0c096ed","_type":"span","marks":[],"text":"\nPartner with us to design, build, and scale your next breakthrough product."}],"markDefs":[],"style":"normal"},{"_key":"66c1f98305d9","_type":"block","children":[{"_key":"1808846cf6a9","_type":"span","marks":["strong"],"text":"Book a free consultation today"},{"_key":"a784ba64e2fa","_type":"span","marks":[],"text":" and take the first step toward your digital transformation."}],"markDefs":[],"style":"normal"}]}}],"$L14","$L15"]}]
