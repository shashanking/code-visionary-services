8:["$","div",null,{"className":"flex flex-col","children":[["$","$L13",null,{"portfolio":{"id":"aa2d2dcc-195a-4d28-8968-80cadd3afd20","slug":"podcast-research-community-platform","portfolioId":"P00-6","title":"Podcast & Research Community Platform","date":"$D2026-03-19T18:46:00.000Z","author":"Code Visionary Services ","description":"We designed and developed Brain Meets Bytes, a podcast-driven research platform and discussion forum founded by Ki, a neuroresearcher. The platform enables seamless podcast publishing alongside interactive discussions, allowing researchers to engage, share insights, and collaborate. Built with Next.js, Node.js, and AWS, it ensures high performance, scalability, and a smooth content consumption experience.","image":"https://cdn.sanity.io/images/cz1w2qmj/production/940883d506be8cd6e4f48887a7c521e28f9d63bf-1812x868.png?w=800&q=80&auto=format","category":"web-applications","content":[{"_key":"d4132c46a23d","_type":"block","children":[{"_key":"e725ce42dbef","_type":"span","marks":["strong"],"text":"Overview"}],"markDefs":[],"style":"h2"},{"_key":"8df4ace112af","_type":"block","children":[{"_key":"cf47084fc58f","_type":"span","marks":[],"text":"Brain Meets Bytes is a niche digital platform built for the research community — combining a podcast website with an interactive discussion forum. The platform enables researchers to share insights, host conversations, and engage in meaningful discussions around complex topics."}],"markDefs":[],"style":"normal"},{"_key":"93e27815f46b","_type":"block","children":[{"_key":"c5237a04d8ef","_type":"span","marks":[],"text":"Founded by Ki, a neuroresearcher and podcast host, the vision was to create a centralized space where knowledge exchange goes beyond publications — making it more conversational, accessible, and collaborative."}],"markDefs":[],"style":"normal"},{"_key":"f466abf8f097","_type":"block","children":[{"_key":"964666f4f1e4","_type":"span","marks":["strong"],"text":"The Challenge"}],"markDefs":[],"style":"h2"},{"_key":"8badc87e617e","_type":"block","children":[{"_key":"91a2e1de8dc6","_type":"span","marks":[],"text":"The project required more than just a content website. The key challenges included:"}],"markDefs":[],"style":"normal"},{"_key":"4827accedc70","_type":"block","children":[{"_key":"ae4ed5c317fb","_type":"span","marks":[],"text":"Creating a platform that supports both "},{"_key":"47c7b776233a","_type":"span","marks":["strong"],"text":"podcast publishing and community discussions"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"de74e90c35b1","_type":"block","children":[{"_key":"a1129d779eaf","_type":"span","marks":[],"text":"Designing an intuitive experience for "},{"_key":"d813546b34b3","_type":"span","marks":["strong"],"text":"researchers and academic users"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"5b26bd1c6f0a","_type":"block","children":[{"_key":"100e18bd18a7","_type":"span","marks":[],"text":"Managing "},{"_key":"9379c5367964","_type":"span","marks":["strong"],"text":"audio content delivery and scalability"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"d7fcaead515b","_type":"block","children":[{"_key":"ac87a52c842f","_type":"span","marks":[],"text":"Building a system that encourages "},{"_key":"8824a512335a","_type":"span","marks":["strong"],"text":"engagement and knowledge sharing"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"506791558d60","_type":"block","children":[{"_key":"9f39466c205e","_type":"span","marks":[],"text":"Ensuring performance while handling "},{"_key":"a4202d9d7057","_type":"span","marks":["strong"],"text":"media-heavy content"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"d1325443ebec","_type":"block","children":[{"_key":"3e3616decb2b","_type":"span","marks":[],"text":"The goal was to bridge the gap between passive content consumption and active intellectual exchange."}],"markDefs":[],"style":"normal"},{"_key":"8d0a46cca455","_type":"block","children":[{"_key":"d7b855290d99","_type":"span","marks":["strong"],"text":"Our Approach"}],"markDefs":[],"style":"h2"},{"_key":"cdb1c188b6de","_type":"block","children":[{"_key":"ea8ba222c221","_type":"span","marks":[],"text":"We focused on building a seamless and scalable platform tailored to the research ecosystem."}],"markDefs":[],"style":"normal"},{"_key":"45cf679c495f","_type":"block","children":[{"_key":"301d78f12d3c","_type":"span","marks":["strong"],"text":"Content + Community Integration"},{"_key":"04ef3110cb3a","_type":"span","marks":[],"text":"\nUnified podcast publishing with a discussion forum to encourage deeper engagement."}],"markDefs":[],"style":"normal"},{"_key":"5d7affdd4533","_type":"block","children":[{"_key":"01570bbc69a8","_type":"span","marks":["strong"],"text":"User-Centric Experience"},{"_key":"67c08a097535","_type":"span","marks":[],"text":"\nDesigned a clean, distraction-free interface suited for long-form content and academic users."}],"markDefs":[],"style":"normal"},{"_key":"c48e956cced8","_type":"block","children":[{"_key":"b32845e41ac2","_type":"span","marks":["strong"],"text":"Scalable Architecture"},{"_key":"29e0092e164e","_type":"span","marks":[],"text":"\nBuilt the platform to handle growing content, users, and media efficiently."}],"markDefs":[],"style":"normal"},{"_key":"bc94201fb4cf","_type":"block","children":[{"_key":"bb1fd19569aa","_type":"span","marks":["strong"],"text":"Performance Optimization"},{"_key":"1cded7079d00","_type":"span","marks":[],"text":"\nEnsured fast loading speeds and smooth playback for audio content."}],"markDefs":[],"style":"normal"},{"_key":"96a645c87cc1","_type":"block","children":[{"_key":"61ed2620ffe6","_type":"span","marks":["strong"],"text":"Structured Content Flow"},{"_key":"2db5c4308ad3","_type":"span","marks":[],"text":"\nOrganized podcasts, topics, and discussions for easy navigation and discovery."}],"markDefs":[],"style":"normal"},{"_key":"0f5615689d9a","_type":"block","children":[{"_key":"489bdfacfbce","_type":"span","marks":["strong"],"text":"The Solution"}],"markDefs":[],"style":"h2"},{"_key":"523b47fe328c","_type":"block","children":[{"_key":"f0771b93de9a","_type":"span","marks":[],"text":"We developed a full-stack web platform that brings together content, conversation, and community:"}],"markDefs":[],"style":"normal"},{"_key":"479e9c5d6d58","_type":"block","children":[{"_key":"024af4758dbd","_type":"span","marks":[],"text":"Podcast hosting and episode management system"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"8a960432c7aa","_type":"block","children":[{"_key":"68ae9d933201","_type":"span","marks":[],"text":"Dedicated discussion forums linked to topics and episodes"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"24581656dc86","_type":"block","children":[{"_key":"a19e6d374949","_type":"span","marks":[],"text":"User authentication and participation features"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"1f0ff649d7a3","_type":"block","children":[{"_key":"81b2f0e10907","_type":"span","marks":[],"text":"Clean, minimal UI for focused reading and listening"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"6322a7d76ff7","_type":"block","children":[{"_key":"2f37da65b6b3","_type":"span","marks":[],"text":"Optimized media delivery for seamless playback"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"4c8b9e7234f8","_type":"block","children":[{"_key":"39c15ff5d37b","_type":"span","marks":[],"text":"The platform allows Ki to host, publish, and manage podcasts while enabling researchers to interact, discuss, and collaborate."}],"markDefs":[],"style":"normal"},{"_key":"c120bcd543a8","_type":"block","children":[{"_key":"9af88e5681d6","_type":"span","marks":["strong"],"text":"Technology Stack"}],"markDefs":[],"style":"h2"},{"_key":"922b1349ff4f","_type":"block","children":[{"_key":"bde40597cfe8","_type":"span","marks":[],"text":"The platform was built using modern, scalable technologies:"}],"markDefs":[],"style":"normal"},{"_key":"09d97f60e2f4","_type":"block","children":[{"_key":"34794b221183","_type":"span","marks":["strong"],"text":"Next.js"},{"_key":"4aff84d92f06","_type":"span","marks":[],"text":" for fast, SEO-friendly frontend performance"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"646916ee813d","_type":"block","children":[{"_key":"342aa0c2730f","_type":"span","marks":["strong"],"text":"Node.js"},{"_key":"e9cb6f8495ea","_type":"span","marks":[],"text":" for backend logic and API handling"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"2920f7424c77","_type":"block","children":[{"_key":"36a7ea69b3b5","_type":"span","marks":["strong"],"text":"AWS"},{"_key":"598494b87cc7","_type":"span","marks":[],"text":" for scalable hosting, storage, and media delivery"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"6edaa4593f42","_type":"block","children":[{"_key":"f80afa849b84","_type":"span","marks":[],"text":"This ensured high performance, reliability, and future scalability."}],"markDefs":[],"style":"normal"},{"_key":"e8882e13f832","_type":"block","children":[{"_key":"1821112bb2be","_type":"span","marks":["strong"],"text":"Results"}],"markDefs":[],"style":"h2"},{"_key":"98b99f5dbb5e","_type":"block","children":[{"_key":"e46d6b4eab14","_type":"span","marks":[],"text":"The platform successfully created a digital space for intellectual exchange:"}],"markDefs":[],"style":"normal"},{"_key":"0072c313d18a","_type":"block","children":[{"_key":"b24c1487c16d","_type":"span","marks":[],"text":"Streamlined podcast publishing and management"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"74ff22225bbc","_type":"block","children":[{"_key":"71270e3283d2","_type":"span","marks":[],"text":"Increased engagement through integrated discussions"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"ceef3ea008b5","_type":"block","children":[{"_key":"252b5f7843ba","_type":"span","marks":[],"text":"Smooth performance even with media-heavy content"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"5aaebe4cfa3a","_type":"block","children":[{"_key":"05fee40f771b","_type":"span","marks":[],"text":"Scalable infrastructure to support future growth"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"9c96692f4cc1","_type":"block","children":[{"_key":"43680e94bc99","_type":"span","marks":[],"text":"Strong foundation for building a niche research community"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"03d771f34248","_type":"block","children":[{"_key":"30033a2077b6","_type":"span","marks":["strong"],"text":"Conclusion"}],"markDefs":[],"style":"h2"},{"_key":"47b5c882f2af","_type":"block","children":[{"_key":"8852ca4465ec","_type":"span","marks":[],"text":"Brain Meets Bytes is more than a website — it’s a knowledge-sharing ecosystem."}],"markDefs":[],"style":"normal"},{"_key":"2e3976e17ff7","_type":"block","children":[{"_key":"c551b4e3cfd3","_type":"span","marks":[],"text":"By combining content with conversation, we helped transform passive listening into active engagement, enabling researchers to connect, discuss, and collaborate in a meaningful way."}],"markDefs":[],"style":"normal"}]}}],"$L14","$L15"]}]
