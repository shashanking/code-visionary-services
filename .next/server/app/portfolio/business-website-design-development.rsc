8:["$","div",null,{"className":"flex flex-col","children":[["$","$L13",null,{"portfolio":{"id":"3109d43d-bef1-4f9e-b73c-128e25614258","slug":"business-website-design-development","portfolioId":"P00-5","title":"Business Website Design & Development","date":"$D2026-03-19T18:43:00.000Z","author":"Code Visionary Services ","description":"We designed and developed the Bensen Solutions website to create a strong digital presence focused on clarity, credibility, and lead generation. With a clean UI, structured service pages, and conversion-driven design, the platform enhances user experience while driving business inquiries. Optimized for performance and responsiveness, the website positions Bensen Solutions as a trusted and professional service provider.","image":"https://cdn.sanity.io/images/cz1w2qmj/production/e72e16748a211ca6e77e4c43e06302289787228a-1812x868.png?w=800&q=80&auto=format","category":"web-applications","content":[{"_key":"9c3fba8b2a2f","_type":"block","children":[{"_key":"70c8db142168","_type":"span","marks":["strong"],"text":"Overview"}],"markDefs":[],"style":"h2"},{"_key":"5e908fd3e67c","_type":"block","children":[{"_key":"d3c8dfc0e6de","_type":"span","marks":[],"text":"Bensen Solutions is a business-focused website designed to present services, build credibility, and generate high-quality leads. The goal was to create a strong digital presence that communicates expertise clearly while maintaining a modern and professional aesthetic."}],"markDefs":[],"style":"normal"},{"_key":"fa6f88fce6bf","_type":"block","children":[{"_key":"20e273fbe3d9","_type":"span","marks":[],"text":"We worked on designing and developing a website that not only reflects the brand’s identity but also drives conversions through structured content and seamless user experience."}],"markDefs":[],"style":"normal"},{"_key":"9fe147909c0b","_type":"block","children":[{"_key":"4918f9722cd4","_type":"span","marks":["strong"],"text":"The Challenge"}],"markDefs":[],"style":"h2"},{"_key":"3d8350e8bea4","_type":"block","children":[{"_key":"14cd410fb109","_type":"span","marks":[],"text":"The project required balancing branding with performance:"}],"markDefs":[],"style":"normal"},{"_key":"9a44d15d2a28","_type":"block","children":[{"_key":"8f4a405645fa","_type":"span","marks":[],"text":"Presenting complex service offerings in a "},{"_key":"c65847a668e9","_type":"span","marks":["strong"],"text":"clear and structured way"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"28799d614c91","_type":"block","children":[{"_key":"d283c2afcd62","_type":"span","marks":[],"text":"Creating a "},{"_key":"e54ed353b74d","_type":"span","marks":["strong"],"text":"trust-driven design"},{"_key":"be39e586b79a","_type":"span","marks":[],"text":" to establish credibility"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"1526233e2939","_type":"block","children":[{"_key":"2067174ecd4f","_type":"span","marks":[],"text":"Ensuring the website is optimized for "},{"_key":"8ad98b54a093","_type":"span","marks":["strong"],"text":"lead generation"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"4ef73d3e6188","_type":"block","children":[{"_key":"6f45ffbd52cc","_type":"span","marks":[],"text":"Building a responsive experience across all devices"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"87935ad19a43","_type":"block","children":[{"_key":"14c9ff099ab4","_type":"span","marks":[],"text":"Maintaining performance while delivering a visually rich interface"}],"level":1,"listItem":"bullet","markDefs":[],"style":"normal"},{"_key":"1c24f31309d4","_type":"block","children":[{"_key":"efc96db8bc2e","_type":"span","marks":[],"text":"The challenge was to make the website both informative and conversion-focused."}],"markDefs":[],"style":"normal"},{"_key":"fa2af96a8232","_type":"block","children":[{"_key":"cdd129b25146","_type":"span","marks":["strong"],"text":"Our Approach"}],"markDefs":[],"style":"h2"},{"_key":"23a930e3fc29","_type":"block","children":[{"_key":"dfefb32f51f7","_type":"span","marks":[],"text":"We focused on clarity, usability, and business outcomes."}],"markDefs":[],"style":"normal"},{"_key":"978a65edf80c","_type":"block","children":[{"_key":"4fd5b468712a","_type":"span","marks":["strong"],"text":"Strategic UI/UX Design"},{"_key":"0ccd2b77b69a","_type":"span","marks":[],"text":"\nDesigned a clean, professional interface that communicates value instantly."}],"markDefs":[],"style":"normal"},{"_key":"2c0b92b09f3b","_type":"block","children":[{"_key":"0157185a440d","_type":"span","marks":["strong"],"text":"Conversion-Focused Structure"},{"_key":"fd9e2f9a5fb0","_type":"span","marks":[],"text":"\nBuilt clear user journeys with strong CTAs to drive inquiries and engagement."}],"markDefs":[],"style":"normal"},{"_key":"9eff2cb3c199","_type":"block","children":[{"_key":"4dba2b27b412","_type":"span","marks":["strong"],"text":"Responsive Development"},{"_key":"34f8e7120000","_type":"span","marks":[],"text":"\nEnsured seamless performance across desktop, tablet, and mobile devices."}],"markDefs":[],"style":"normal"},{"_key":"08490ace04b2","_type":"block","children":[{"_key":"e43a582055e1","_type":"span","marks":["strong"],"text":"Performance Optimization"},{"_key":"fc9a2a0334ac","_type":"span","marks":[],"text":"\nOptimized loading speed, structure, and overall responsiveness."}],"markDefs":[],"style":"normal"},{"_key":"92873858eeb4","_type":"block","children":[{"_key":"04399a35f01c","_type":"span","marks":["strong"],"text":"Content Structuring"},{"_key":"c1444c98bc4c","_type":"span","marks":[],"text":"\nOrganized services and messaging to improve readability and user understanding."}],"markDefs":[],"style":"normal"},{"_key":"66cd30fa30ec","_type":"block","children":[{"_key":"98f6a90b51b8","_type":"span","marks":["strong"],"text":"The Solution"}],"markDefs":[],"style":"h2"},{"_key":"100520d56143","_type":"block","children":[{"_key":"7171a90361c5","_type":"span","marks