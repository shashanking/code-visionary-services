8:["$","div",null,{"className":"bg-[#F0F0F0] min-h-screen","children":[["$","$L13",null,{"blog":{"id":"CoXljdUpHLN0XegRK1q65G","slug":"building-sanity-best-practices-skill","blogId":"99","title":"Building the Sanity Best Practices Skill with MCP","date":"$D2026-02-01T00:00:00.000Z","author":"CVS","description":"How CVS is standardizing content operations with a new AI-driven Sanity skill.","image":"https://cdn.sanity.io/images/cz1w2qmj/production/8350ffd1428ede15ac9c6a256befc014ba6d791b-3840x2160.png?w=800&q=80&auto=format","readTime":"3 min read","content":[{"_key":"yEYwvbhpDrCFHYzchkbs8u","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbsDl","_type":"span","text":"Building the Sanity Best Practices Skill"}],"style":"h1"},{"_key":"yEYwvbhpDrCFHYzchkbsIc","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbsNT","_type":"span","text":"At CVS, we don't just use tools; we master them. We've built a comprehensive Sanity Best Practices skill to ensure our content infrastructure is scalable, performant, and maintainable."}],"style":"normal"},{"_key":"yEYwvbhpDrCFHYzchkbsSK","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbsXB","_type":"span","text":"Why This Matters"}],"style":"h2"},{"_key":"yEYwvbhpDrCFHYzchkbsc2","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbsgt","_type":"span","text":"Sanity is powerful, but flexibility can lead to chaos. Without rules, schemas become bloated, queries get slow, and the Studio becomes cluttered. Our new skill codifies the \"CVS Way\" of building with Sanity."}],"style":"normal"},{"_key":"yEYwvbhpDrCFHYzchkbslk","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbsqb","_type":"span","text":"The 10 Commandments of Sanity"}],"style":"h2"},{"_key":"yEYwvbhpDrCFHYzchkbsvS","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbt0J","_type":"span","text":"We've organized our best practices into 10 high-impact categories:"}],"style":"normal"},{"_key":"yEYwvbhpDrCFHYzchkbt5A","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbtA1","_type":"span","text":"1.  **GROQ Performance**: Optimizing queries is our #1 priority. Fast content = fast sites."}],"listItem":"bullet","style":"normal"},{"_key":"yEYwvbhpDrCFHYzchkbtEs","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbtJj","_type":"span","text":"2.  **Schema Design**: We prioritize data structure over presentation. 3.  **Visual Editing**: Enabling true live previews for editors. 4.  **Images**: Handling hotspots, crops, and LQIP efficiently. 5.  **Portable Text**: Using custom components correctly. 6.  **Page Builder**: Structuring modular content. 7.  **Studio Configuration**: Cleaning up the desk for our creators. 8.  **TypeGen**: Ensuring type safety across the board. 9.  **Localization**: Handling global content the right way. 10. **Migration**: Moving data without breaking things."}],"style":"normal"},{"_key":"yEYwvbhpDrCFHYzchkbtOa","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbtTR","_type":"span","text":"Applying the Skill"}],"style":"h2"},{"_key":"yEYwvbhpDrCFHYzchkbtYI","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbtd9","_type":"span","text":"This skill isn't just a document; it's a tool we use to review code, design schemas, and optimize our stack. It ensures that every new feature we build aligns with our standards for speed and leverage."}],"style":"normal"},{"_key":"yEYwvbhpDrCFHYzchkbti0","_type":"block","children":[{"_key":"yEYwvbhpDrCFHYzchkbtmr","_type":"span","text":"By building this into our workflow, we ensure that our content platform remains a competitive advantage, not a technical debt generator."}],"style":"normal"}]}}],["$","$L14",null,{"content":"$8:props:children:0:props:blog:content"}],["$","$L15",null,{"currentBlogId":"CoXljdUpHLN0XegRK1q65G"}]]}]
