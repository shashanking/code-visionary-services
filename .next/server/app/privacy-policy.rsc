8:["$","div",null,{"className":"flex justify-center mx-6 ","children":["$","div",null,{"className":"max-w-[1400px] sm:mx-6 my-6  text-gray-800","children":[["$","div",null,{"children":[["$","p",null,{"children":"Code Visionary Services (“we”, “our”, or “us”) is committed to protecting your privacy. This Privacy Policy explains how your personal information is collected, used, and disclosed by Code Visionary Services."}],["$","p",null,{"children":["This Privacy Policy applies to our website,"," ",["$","a",null,{"href":"https://www.codevisionaryservices.com/","children":"https://www.codevisionaryservices.com/"}],", and its associated subdomains (collectively, our “Service”). By accessing or using our Service, you signify that you have read, understood, and agree to our collection, storage, use, and disclosure of your personal information as described in this Privacy Policy and our Terms of Service."]}]]}],["$","div",null,{"children":[["$","h2",null,{"children":["$","strong",null,{"children":"Definitions and Key Terms"}]}],["$","p",null,{"children":[["$","strong",null,{"children":"Cookie:"}]," Small amount of data generated by a website and saved by your web browser. It is used to identify your browser, provide analytics, and remember information about you such as your language preference or login information."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Country:"}]," Where Code Visionary Services or the owners/founders of CodeVisionaryServices are based, in this case, is India."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Customer:"}]," Refers to the company, organization or person that signs up to use the CodeVisionaryServices Service to manage the relationships with your consumers or service users."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Device:"}]," Any internet-connected device such as a phone, tablet, computer or any other device that can be used to visit Code Visionary Services and use the services."]}],["$","p",null,{"children":[["$","strong",null,{"children":"IP Address:"}]," Every device connected to the Internet is assigned a number known as an Internet protocol (IP) address. These numbers are usually assigned in geographic blocks. An IP address can often be used to identify the location from which a device is connecting to the Internet."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Personnel:"}]," Refers to those individuals who are employed by CodeVisionaryServices or are under contract to perform a service on behalf of one of the parties."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Personal Data:"}]," Any information that directly, indirectly, or in connection with other information including a personal identification number allows for the identification or identifiability of a natural person."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Service:"}]," Refers to the service provided by CodeVisionaryServices as described in the relative terms (if available) and on this platform."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Third-party service:"}]," Refers to advertisers, contest sponsors, promotional and marketing partners, and others who provide our content or whose products or services we think may interest you."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Website:"}]," Code Visionary Services’s site, which can be accessed via this URL:"," ",["$","a",null,{"href":"https://www.codevisionaryservices.com/","children":"https://www.codevisionaryservices.com/"}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"You:"}]," A person or entity that is registered with CodeVisionaryServices to use the Services."]}]]}],["$","div",null,{"children":[["$","h2",null,{"children":["$","strong",null,{"children":"What Information Do We Collect?"}]}],"$Lc","$Ld"]}],"$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17"]}]}]
